# ================================
# 数据库
# ================================
POSTGRES_USER=xhs
POSTGRES_PASSWORD=xhs_dev_password
POSTGRES_DB=xhs_marketing
DATABASE_URL=postgresql+asyncpg://xhs:xhs_dev_password@localhost:5432/xhs_marketing

# ================================
# Redis
# ================================
REDIS_URL=redis://localhost:6379/0

# ================================
# RabbitMQ
# ================================
RABBITMQ_USER=xhs
RABBITMQ_PASSWORD=xhs_dev_password
RABBITMQ_URL=amqp://xhs:xhs_dev_password@localhost:5672/

# ================================
# Qdrant
# ================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ================================
# LLM
# ================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# 可选：替换为国产模型
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ================================
# 图像生成
# ================================
DALLE_MODEL=dall-e-3

# ================================
# 加密密钥（用于 OAuth Token / Cookie 加密存储）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ================================
ENCRYPTION_KEY=your-fernet-key-here

# ================================
# JWT
# ================================
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ================================
# 小红书平台
# ================================
XHS_WEBHOOK_SECRET=your-webhook-secret-here

# ================================
# 应用配置
# ================================
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
